# ─── REQUIRED (personal trading) ─────────────────────────────
PRIVATE_KEY=0x...your-wallet-private-key
LIMITLESS_API_KEY=lmts_...your-api-key

# ─── HMAC / SCOPED TOKEN AUTH (partner/programmatic mode) ────
# Use these instead of LIMITLESS_API_KEY for partner integrations.
# Derived via POST /auth/api-tokens/derive with a Privy identity token.
# LMTS_TOKEN_ID=your-token-id
# LMTS_TOKEN_SECRET=your-base64-secret

# ─── SAFETY ──────────────────────────────────────────────────
DRY_RUN=true
MAX_TOTAL_EXPOSURE_USD=50
MAX_SINGLE_TRADE_USD=10

# ─── OPTIONAL ────────────────────────────────────────────────
COINGECKO_API_KEY=CG-...optional-for-signal-strategy
LOG_LEVEL=info
# LIMITLESS_API_URL=https://api.limitless.exchange
# LIMITLESS_WS_URL=wss://ws.limitless.exchange

# ─── ORACLE ARB STRATEGY (W4 extensions) ────────────────────
# Oracle-arb (W4 extensions)
ORACLE_ENABLED=false
ORACLE_BET_SIZE=1
ORACLE_ASSETS=BTC,ETH,SOL              # XRP,DOGE supported, opt-in
ORACLE_TIMEFRAMES=1h                    # 5m,15m supported, opt-in
ORACLE_MAX_PRICE=0.75
ORACLE_MIN_EDGE=0.10

# ─── RISK ENGINE (W1) ────────────────────────────────────────
# Per-trade USD cap (rejected if order.sizeUsd > LIVE_BET_MAX)
LIVE_BET_MAX=5
# Daily PnL floor in USD; once reached, all new orders blocked for the day
LIVE_LOSS_CAP=-50
# Drawdown halt threshold as % of today's peak equity
DRAWDOWN_HALT_PCT=10
# BTC/ETH/SOL combined exposure cap as multiple of LIVE_BET_MAX
CORRELATION_GROUP_CAP=1.5
# Auto-halt after this many consecutive resolved losses
ADVERSE_HALT_LOSSES=5
# High-vol regime size factor (consumed by future strategies, not gate logic)
VOL_REGIME_HIGH_FACTOR=2.0
# Reject order if Pyth confidence/price exceeds this percentage
PYTH_CONF_GATE_PCT=0.5
# NOTE: MAX_TOTAL_EXPOSURE_USD already defined in SAFETY section above —
# the W1 risk gate reads it from there. Pass 3 should dedupe if both end
# up present.
# MAX_TOTAL_EXPOSURE_USD=50
# Optional: override risk DB path (default /var/lib/knoxis/knoxis-limitless.db)
# RISK_DB_PATH=/var/lib/knoxis/knoxis-limitless.db

# ── Maker complement arb (W2) ──
MAKER_ENABLED=false
MAKER_MARKETS=                       # comma-sep slugs, populated at runtime
MAKER_TARGET_SUM=0.95                # YES + NO bid targets must sum <= this
MAKER_QUOTE_BUMP_BPS=10              # post 10bps inside best bid
MAKER_REQUOTE_TOLERANCE=0.005        # requote if drift > 0.5c (probability units)
MAKER_MAX_INVENTORY_PER_MARKET=20    # USD cap per side per market
MAKER_BET_SIZE=2                     # USD per quote
