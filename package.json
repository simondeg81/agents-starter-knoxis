{
  "name": "agents-starter",
  "version": "1.0.0",
  "description": "Build autonomous trading agents for Limitless Exchange prediction markets on Base",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/risk/gates/__tests__/per-trade-size.test.ts src/strategies/maker-complement/__tests__/quote-engine.test.ts src/strategies/oracle-arb/__tests__/dry-run-gating.test.ts src/council/__tests__/key-isolation-check.test.ts tests/event-bus.test.ts tests/sqlite-writer.test.ts tests/venues.test.ts",
    "start": "npx tsx src/index.ts",
    "demo": "npx tsx src/demo.ts",
    "dashboard": "npx tsx src/dashboard.ts",
    "signal-sniper": "npx tsx src/strategies/signal-sniper/run.ts",
    "complement-arb": "npx tsx src/strategies/cross-market-arb/run.ts",
    "cross-market-arb": "npx tsx src/strategies/cross-market-arb/run.ts",
    "oracle-arb": "npx tsx src/strategies/oracle-arb/run.ts",
    "iterate": "npx tsx src/strategies/iterate.ts",
    "iterate:analyze": "npx tsx src/strategies/iterate.ts analyze",
    "iterate:markets": "npx tsx src/strategies/iterate.ts markets",
    "redeem": "npx tsx src/core/limitless/redeem.ts",
    "conviction-sniper": "tsx src/strategies/conviction-sniper/run.ts"
  },
  "keywords": [
    "prediction-markets",
    "trading-bot",
    "limitless",
    "base-chain",
    "defi"
  ],
  "author": "Limitless Labs",
  "license": "MIT",
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "better-sqlite3": "^11.3.0",
    "cross-fetch": "^4.1.0",
    "dotenv": "^16.4.0",
    "eventsource": "^4.1.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "socket.io-client": "^4.8.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "viem": "^2.20.0"
  }
}
